{{- $pages := where .Site.RegularPages "Type" "blog" -}}
[
{{- range $i, $page := $pages }}
  {{- if $i }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "date": {{ $page.Date.Format "January 2, 2006" | jsonify }},
    "dateMachine": {{ $page.Date.Format "2006-01-02T15:04:05-07:00" | jsonify }},
    "description": {{ $page.Params.description | default "" | jsonify }},
    "tags": [{{ range $j, $tag := $page.GetTerms "tags" }}{{ if $j }},{{ end }}{{ $tag.LinkTitle | jsonify }}{{ end }}]
  }
{{- end }}
]
